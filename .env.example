# Contact form — Web3Forms server-side lead capture.
# Get a free access key at https://web3forms.com (enter the destination inbox —
# e.g. service@metrotv-audiotech.com — and confirm the verification email; no
# account or DNS setup required). Copy this file to `.env.local` and paste the key.
#
# This is a PUBLIC access key (it only routes mail to the inbox you registered),
# so the NEXT_PUBLIC_ prefix is intentional and safe to ship to the browser.
# With this unset, the form falls back to opening a mailto: draft.
NEXT_PUBLIC_WEB3FORMS_KEY=

# Google tag (gtag.js) / GA4 measurement ID. Optional — the live ID is hardcoded
# as a fallback in components/Analytics.tsx (a GA measurement ID is public and
# ships in page source regardless). Set this only to point analytics at a
# different property without touching code.
NEXT_PUBLIC_GA_ID=G-91M6FW7C7B
